# we can use across() function to apply changes across columns
# changes the selected columns to integer values 
region_lang |>
  mutate(across(mother_tongue:lang_known, as.integer))
____________________________________________________________________________________________

# applying row-based functions is a little more complicated
# we use the function rowwise to compensate
# rowwise dictates that for the following outputs, the change would be applied based on rows rather than affecting the whole column

    region_lang |>
        select(mother_tongue:lang_known) |>
        rowwise() |>
        mutate(maximum = max(c(mother_tongue,
                             most_at_home,
                             most_at_work,
                             lang_known)))

# we can use the filter functions to filter rows
    official_langs <- filter (tidy_lang, category == "official languages")
    
#  == is an equivalency operator; it tells R to select "official languages"
#  != is an DISequivalency operator; it tells R to select all values in "category" OTHER THAN "official languages"


# Below is an example of using a comma to filter rows where both conditions are satisfied. You can use "&" and "," interchangably.

    filter(official_langs, region == "Montréal", language == "French")


# We can use the "|" to filter rows where EITHER condition is satisfied (can be both)

    filter(official_langs, region == "Montréal"| language == "French")


 
# the %in% operator is different than == in the sense that 

# "vectorA %in% vectorB" compares the first element of vectorA to all the elements in vectorB
